  color: #dfe6e9;
}

/* Syntax Highlighting — same palette as home */
pre code .t  { color: #7c8aff; }
pre code .a  { color: #f8a5c2; }
pre code .s  { color: #55efc4; }
pre code .k  { color: #fd79a8; }
pre code .tp { color: #74b9ff; }
pre code .v  { color: #dfe6e9; }
pre code .f  { color: #ffeaa7; }
pre code .n  { color: #fab1a0; }
pre code .i  { color: #fdcb6e; }
pre code .c  { color: #e17055; }
pre code .d  { color: #a29bfe; }
pre code .cm { color: #636e72; }
pre code .cs { color: #81ecec; }

/* Notes and Warnings */
.note, .warning, .note-text {
  padding: 1rem;
  border-radius: 0.5rem;
  margin: 1rem 0;
  font-size: 0.9rem;
}

.note {
  background: rgba(0, 184, 148, 0.1);
  border-left: 3px solid var(--c-accent);
  color: var(--c-text);
}

.note strong {
  color: var(--c-accent);
}

.note ul, .note li {
  margin: 0.5rem 0;
  padding-left: 1.5rem;
}

.warning {
  background: rgba(255, 107, 107, 0.1);
  border-left: 3px solid #ff6b6b;
  color: var(--c-text);
}

.warning strong {
  color: #ff6b6b;
}

.note-text {
  background: transparent;
  padding: 0.5rem 0;
  margin: 0.5rem 0;
  border-left: 3px solid var(--c-primary);
  padding-left: 0.75rem;
  color: var(--c-text-dim);
  font-size: 0.9rem;
  font-style: italic;
}

.example-title {
  font-weight: 600;
  color: var(--c-primary);
  margin-top: 1rem;
  margin-bottom: 0.5rem;
  font-size: 0.9rem;
}

/* Responsive Design */
@media (max-width: 1024px) {
  .page-container {
    grid-template-columns: 240px 1fr;
  }

  .sidebar {
    padding: 1rem;
  }

  .content {
    padding: 1.5rem;
  }
}

@media (max-width: 768px) {
  .page-container {
    grid-template-columns: 1fr;
  }

  .sidebar {
    position: fixed;
    left: 0;
    top: 0;
    width: 280px;
    height: 100vh;
    transform: translateX(-100%);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 1000;
    box-shadow: 2px 0 8px rgba(0, 0, 0, 0.3);
  }

  .sidebar.open {
    transform: translateX(0);
  }

  .sidebar-toggle {
    display: flex;
  }

  .content {
    padding: 1rem;
  }

  .page-header h1 {
    font-size: 1.8rem;
  }

  .doc-section h2 {
    font-size: 1.4rem;
  }

  .doc-section h3 {
    font-size: 1.1rem;
  }

  pre {
    padding: 0.75rem;
    font-size: 0.8rem;
  }

  code {
    font-size: 0.8rem;
  }
}

@media (max-width: 480px) {
  .page-header h1 {
    font-size: 1.5rem;
  }

  .subtitle {
    font-size: 0.95rem;
  }

  .doc-section h2 {
    font-size: 1.25rem;
  }

  .doc-section h3 {
    font-size: 1rem;
  }

  .content {
    padding: 0.75rem;
  }

  pre {
    padding: 0.5rem;
    font-size: 0.75rem;
  }
}

/* Scrollbar Styling */
:host ::-webkit-scrollbar {
  width: 8px;
  height: 8px;
}

:host ::-webkit-scrollbar-track {
  background: var(--c-bg);
}

:host ::-webkit-scrollbar-thumb {
  background: var(--c-border);
  border-radius: 4px;
}

:host ::-webkit-scrollbar-thumb:hover {
  background: var(--c-text-dim);
}

/* Smooth Scrolling */
html {
  scroll-behavior: smooth;
}

/* Links */
a {
  color: var(--c-primary);
  text-decoration: none;
  transition: color 0.2s ease;
}

a:hover {
  color: var(--c-primary-light);
  text-decoration: underline;
}

/* Typography */
strong {
  font-weight: 600;
  color: var(--c-text);
}

em {
  font-style: italic;
  color: var(--c-text-dim);
}
</style>
