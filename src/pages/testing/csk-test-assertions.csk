<meta>
  name: csk-test-assertions
  shadow: none
</meta>

<script>
  fn tr(k: string) { return window.__t(k) }
  state exampleAssert: string = "const { suite, compileOk } = require('./lib/chasket-test');\n\nsuite('Assertions', t => {\n  t.test('basic assertions', () => {\n    t.assert(true, 'is truthy');\n    t.eq(5, 5, 'values equal');\n    t.deepEq({ a: 1 }, { a: 1 }, 'deep equal');\n    t.includes('hello world', 'world', 'includes substring');\n    t.notIncludes('hello', 'xyz', 'excludes substring');\n    t.matches('test123', /\\\\d+/, 'matches regex');\n    t.throws(() => { throw new Error('oops'); }, 'function throws');\n  });\n});\n\nsuite.run();"

  state exampleOutput: string = "const { suite, compileOk, csk } = require('./lib/chasket-test');\n\nsuite('Output Assertions', t => {\n  t.test('verify output', () => {\n    const src = csk({\n      name: 'my-comp',\n      script: 'state msg: string = &quot;hello&quot;',\n      template: '&lt;p&gt;{{ msg }}&lt;/p&gt;'\n    });\n    const r = compileOk(src);\n\n    t.compileSuccess(r);\n    t.validJS(r);\n    t.outputIncludes(r, 'hello');\n    t.outputNotIncludes(r, 'world');\n    t.hasInterpolation(r, 'msg');\n  });\n});\n\nsuite.run();"

  state exampleTemplate: string = "const { suite, compileOk, csk } = require('./lib/chasket-test');\n\nsuite('Template Assertions', t => {\n  t.test('check template output', () => {\n    const src = csk({\n      name: 'my-list',\n      template: '&lt;ul&gt;&lt;#for item of items&gt;&lt;li&gt;{{ item }}&lt;/li&gt;&lt;/#for&gt;&lt;/ul&gt;'\n    });\n    const r = compileOk(src);\n\n    const tpl = t.getTemplate(r);\n    console.log(tpl);  // the extracted template string\n\n    t.templateIncludes(r, '&lt;ul&gt;');\n    t.templateNotIncludes(r, 'invalid');\n  });\n});\n\nsuite.run();"

  state exampleState: string = "const { suite, compileOk, csk } = require('./lib/chasket-test');\n\nsuite('Lifecycle & State', t => {\n  t.test('state and lifecycle', () => {\n    const src = csk({\n      name: 'my-comp',\n      script: '\n        state count: number = 0\n        watch count { console.log(&apos;changed&apos;); }\n        fn increment() { count++; }\n        on mount { console.log(&apos;mounted&apos;); }\n        on unmount { console.log(&apos;unmounted&apos;); }\n      '\n    });\n    const r = compileOk(src);\n\n    t.hasState(r, 'count');\n    t.hasWatch(r, 'count');\n    t.hasOnMount(r, 'console.log');\n    t.hasOnUnmount(r, 'console.log');\n  });\n});\n\nsuite.run();"

  state exampleDiag: string = "const { suite, compileFail } = require('./lib/chasket-test');\n\nsuite('Diagnostics', t => {\n  t.test('diagnostic checks', () => {\n    const src = '&lt;meta&gt;name: &quot;x&quot;&lt;/meta&gt;&lt;template&gt;&lt;p&gt;{{ unknown }}&lt;/p&gt;&lt;/template&gt;';\n    const r = compileFail(src);\n\n    t.compileFails(r);\n    t.hasDiag(r, 'E0301');  // undefined variable\n    t.hasDiag(r, 'E0301', 'error');  // with level\n    t.noDiag(r, 'E0302');\n    t.diagCount(r, 'error', 1);\n  });\n});\n\nsuite.run();"
</script>

<template>
  <!-- Assertions -->
  <section id="assertions" class="doc-section">
    <h2>{{ tr('testContent.assertions.title') }}</h2>

    <div class="subsection">
      <h3 id="assert-basic">{{ tr('testContent.assertions.basicTitle') }}</h3>
      <div class="property">
        <h4>assert(condition, msg)</h4>
        <p>{{ tr('testContent.assertions.assertDesc') }}</p>
      </div>
      <div class="property">
        <h4>eq(actual, expected, msg)</h4>
        <p>{{ tr('testContent.assertions.eqDesc') }}</p>
      </div>
      <div class="property">
        <h4>deepEq(actual, expected, msg)</h4>
        <p>{{ tr('testContent.assertions.deepEqDesc') }}</p>
      </div>
      <div class="property">
        <h4>includes(str, sub, msg)</h4>
        <p>{{ tr('testContent.assertions.includesDesc') }}</p>
      </div>
      <div class="property">
        <h4>notIncludes(str, sub, msg)</h4>
        <p>{{ tr('testContent.assertions.notIncludesDesc') }}</p>
      </div>
      <div class="property">
        <h4>matches(str, regex, msg)</h4>
        <p>{{ tr('testContent.assertions.matchesDesc') }}</p>
      </div>
      <div class="property">
        <h4>throws(fn, msg)</h4>
        <p>{{ tr('testContent.assertions.throwsDesc') }}</p>
      </div>
      <div class="example-title">{{ tr('testContent.assertions.usageExample') }}</div>
      <pre><code>{{{ exampleAssert }}}</code></pre>
    </div>

    <div class="subsection">
      <h3 id="assert-compile">{{ tr('testContent.assertions.compileTitle') }}</h3>
      <div class="property">
        <h4>compileSuccess(result, msg)</h4>
        <p>{{ tr('testContent.assertions.compileSuccessDesc') }}</p>
      </div>
      <div class="property">
        <h4>compileFails(result, msg)</h4>
        <p>{{ tr('testContent.assertions.compileFailsDesc') }}</p>
      </div>
      <div class="property">
        <h4>validJS(result, msg)</h4>
        <p>{{ tr('testContent.assertions.validJSDesc') }}</p>
      </div>
    </div>

    <div class="subsection">
      <h3 id="assert-output">{{ tr('testContent.assertions.outputTitle') }}</h3>
      <div class="property">
        <h4>outputIncludes(result, sub, msg)</h4>
        <p>{{ tr('testContent.assertions.outputIncludesDesc') }}</p>
      </div>
      <div class="property">
        <h4>outputNotIncludes(result, sub, msg)</h4>
        <p>{{ tr('testContent.assertions.outputNotIncludesDesc') }}</p>
      </div>
      <div class="example-title">{{ tr('testContent.assertions.usageExample') }}</div>
      <pre><code>{{{ exampleOutput }}}</code></pre>
    </div>

    <div class="subsection">
      <h3 id="assert-template">{{ tr('testContent.assertions.templateTitle') }}</h3>
      <div class="property">
        <h4>getTemplate(result)</h4>
        <p>{{ tr('testContent.assertions.getTemplateDesc') }}</p>
      </div>
      <div class="property">
        <h4>templateIncludes(result, sub, msg)</h4>
        <p>{{ tr('testContent.assertions.templateIncludesDesc') }}</p>
      </div>
      <div class="property">
        <h4>templateNotIncludes(result, sub, msg)</h4>
        <p>{{ tr('testContent.assertions.templateNotIncludesDesc') }}</p>
      </div>
      <div class="example-title">{{ tr('testContent.assertions.usageExample') }}</div>
      <pre><code>{{{ exampleTemplate }}}</code></pre>
    </div>

    <div class="subsection">
      <h3 id="assert-state">{{ tr('testContent.assertions.stateTitle') }}</h3>
      <div class="property">
        <h4>hasState(result, name, msg)</h4>
        <p>{{ tr('testContent.assertions.hasStateDesc') }}</p>
      </div>
      <div class="property">
        <h4>hasWatch(result, deps, msg)</h4>
        <p>{{ tr('testContent.assertions.hasWatchDesc') }}</p>
      </div>
      <div class="property">
        <h4>hasOnMount(result, bodySubstring, msg)</h4>
        <p>{{ tr('testContent.assertions.hasOnMountDesc') }}</p>
      </div>
      <div class="property">
        <h4>hasOnUnmount(result, bodySubstring, msg)</h4>
        <p>{{ tr('testContent.assertions.hasOnUnmountDesc') }}</p>
      </div>
      <div class="property">
        <h4>hasInterpolation(result, varName, msg)</h4>
        <p>{{ tr('testContent.assertions.hasInterpolationDesc') }}</p>
      </div>
      <div class="example-title">{{ tr('testContent.assertions.usageExample') }}</div>
      <pre><code>{{{ exampleState }}}</code></pre>
    </div>

    <div class="subsection">
      <h3 id="assert-diag">{{ tr('testContent.assertions.diagTitle') }}</h3>
      <div class="property">
        <h4>hasDiag(result, code, level?, msg)</h4>
        <p>{{ tr('testContent.assertions.hasDiagDesc') }}</p>
      </div>
      <div class="property">
        <h4>noDiag(result, code, msg)</h4>
        <p>{{ tr('testContent.assertions.noDiagDesc') }}</p>
      </div>
      <div class="property">
        <h4>diagCount(result, level, expected, msg)</h4>
        <p>{{ tr('testContent.assertions.diagCountDesc') }}</p>
      </div>
      <div class="example-title">{{ tr('testContent.assertions.usageExample') }}</div>
      <pre><code>{{{ exampleDiag }}}</code></pre>
    </div>
  </section>
</template>

<style>
</style>
