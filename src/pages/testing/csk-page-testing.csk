}

/* Documentation Sections */
.doc-section {
  margin-bottom: 3rem;
  scroll-margin-top: 2rem;
}

.doc-section h2 {
  font-size: 1.8rem;
  font-weight: 700;
  margin: 0 0 1rem 0;
  color: var(--c-text);
  padding-bottom: 0.5rem;
