<meta>
  name: csk-page-testing
  shadow: none
</meta>

<script>
  // csk-page-testing: テストフレームワーク文書の親ページ
  // shadow: none — サブコンポーネント（csk-test-*）がライト DOM でスタイルを共有。
  // TOC パターンは csk-page-guide と同一（ARCHITECTURE.md §7 参照）。
  // ⚠️ activeSection を state にしないこと（#patch() がサブコンポーネントを破壊する）。

  state sidebarOpen: boolean = true

  fn tr(k: string) { return window.__t(k) }

  fn toggleSidebar() {
    sidebarOpen = !sidebarOpen
  }

  fn handleTocClick(e: Event) {
    const link = e.target.closest('a')
    if (!link) return
    const href = link.getAttribute('href')
    if (href && href.startsWith('#') && !href.startsWith('#/')) {
      e.preventDefault()
      const el = document.getElementById(href.substring(1))
      if (el) el.scrollIntoView({ behavior: 'smooth' })
    }
  }

  fn updateActiveLink(sectionId: string) {
    const links = document.querySelectorAll('.toc a')
    links.forEach((link) => {
      const href = link.getAttribute('href')
      if (href && href.substring(1) === sectionId) {
        link.classList.add('active')
      } else {
        link.classList.remove('active')
      }
    })
  }

  on mount {
    const sections = document.querySelectorAll('.doc-section[id]')
    const observer = new IntersectionObserver((entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          updateActiveLink(entry.target.id)
        }
      }
    }, { rootMargin: '-20% 0px -70% 0px', threshold: 0 })
    sections.forEach((s) => { observer.observe(s) })
  }
</script>

<template>
  <div class="page-container">
    <!-- Sidebar Navigation -->
    <aside :class="'sidebar ' + (sidebarOpen ? 'open' : 'closed')">
      <div class="sidebar-header">
        <h2>{{ tr('testing.toc') }}</h2>
        <button class="sidebar-toggle" @click="toggleSidebar">
          <span class="toggle-icon">≡</span>
        </button>
      </div>

      <nav class="toc" @click="handleTocClick">
        <ul>
          <li><a href="#overview">{{ tr('testing.sections.overview') }}</a></li>
          <li><a href="#install">{{ tr('testing.sections.install') }}</a></li>
          <li><a href="#quickstart">{{ tr('testing.sections.quickstart') }}</a></li>
          <li>
            <a href="#api-reference">{{ tr('testing.sections.apiReference') }}</a>
            <ul>
              <li><a href="#api-suite">{{ tr('testing.toc_items.suite') }}</a></li>
              <li><a href="#api-test">{{ tr('testing.toc_items.test') }}</a></li>
              <li><a href="#api-lifecycle">{{ tr('testing.toc_items.lifecycle') }}</a></li>
            </ul>
          </li>
          <li>
            <a href="#compile-helpers">{{ tr('testing.sections.compileHelpers') }}</a>
            <ul>
              <li><a href="#compile-ok-fail">{{ tr('testing.toc_items.compileOkFail') }}</a></li>
              <li><a href="#csk-helper">{{ tr('testing.toc_items.cskHelper') }}</a></li>
            </ul>
          </li>
          <li>
            <a href="#assertions">{{ tr('testing.sections.assertions') }}</a>
            <ul>
              <li><a href="#assert-basic">{{ tr('testing.toc_items.basic') }}</a></li>
              <li><a href="#assert-compile">{{ tr('testing.toc_items.compile') }}</a></li>
              <li><a href="#assert-output">{{ tr('testing.toc_items.output') }}</a></li>
              <li><a href="#assert-template">{{ tr('testing.toc_items.template') }}</a></li>
              <li><a href="#assert-state">{{ tr('testing.toc_items.state') }}</a></li>
              <li><a href="#assert-diag">{{ tr('testing.toc_items.diagnostics') }}</a></li>
            </ul>
          </li>
          <li><a href="#full-example">{{ tr('testing.sections.fullExample') }}</a></li>
        </ul>
      </nav>
    </aside>

    <!-- Main Content -->
    <main class="content">
      <!-- Header -->
      <div class="page-header">
        <h1>{{ tr('testing.title') }}</h1>
        <p class="subtitle">{{ tr('testing.subtitle') }}</p>
      </div>

      <!-- Sub-components -->
      <csk-test-overview></csk-test-overview>
      <csk-test-api></csk-test-api>
      <csk-test-compile></csk-test-compile>
      <csk-test-assertions></csk-test-assertions>
      <csk-test-example></csk-test-example>
    </main>
  </div>
</template>

<style>
:host {
  display: block;
  background: var(--c-bg);
  color: var(--c-text);
  font-family: var(--font);
  min-height: 100vh;
}

.page-container {
  display: grid;
  grid-template-columns: 280px 1fr;
  gap: 0;
  max-width: var(--max-w);
  margin: 0 auto;
}

/* Sidebar Navigation */
.sidebar {
  background: var(--c-surface);
  border-right: 1px solid var(--c-border);
  padding: var(--space-page);
  height: 100vh;
  position: sticky;
  top: 0;
  overflow-y: auto;
  overscroll-behavior: contain;
}

.sidebar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 1.5rem;
  padding-bottom: 1rem;
  border-bottom: 1px solid var(--c-border);
}

.sidebar-header h2 {
  font-size: 1rem;
  font-weight: 600;
  margin: 0;
  color: var(--c-text);
}

.sidebar-toggle {
  display: none;
  background: transparent;
  border: none;
  color: var(--c-text);
  font-size: 1.5rem;
  cursor: pointer;
  padding: 0;
  width: 2rem;
  height: 2rem;
  align-items: center;
  justify-content: center;
}

.toc ul {
  list-style: none;
  padding: 0;
  margin: 0;
}

.toc > ul > li {
  margin: 0.25rem 0;
}

.toc a {
  color: var(--c-text-dim);
  text-decoration: none;
  display: block;
  padding: 0.5rem 0.75rem;
  border-radius: 0.375rem;
  font-size: 0.9rem;
  transition: all 0.2s ease;
}

.toc a:hover {
  color: var(--c-primary);
  background: rgba(108, 92, 231, 0.1);
}

.toc a.active {
  color: var(--c-primary);
  background: rgba(108, 92, 231, 0.15);
  font-weight: 600;
}

