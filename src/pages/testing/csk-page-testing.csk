}

.note-text {
  background: rgba(108, 92, 231, 0.05);
  border-left: 3px solid var(--c-text-dim);
  color: var(--c-text-dim);
}

.warning {
  background: rgba(253, 203, 110, 0.1);
  border-left: 3px solid #fdcb6e;
