}

/* Responsive */
@media (max-width: 768px) {
  .page-container {
    grid-template-columns: 1fr;
  }
  .sidebar {
    display: none;
    position: fixed;
    top: 3.75rem;
    left: 0;
    width: 280px;
    height: calc(100vh - 3.75rem);
    z-index: 100;
  }
  .sidebar.open {
