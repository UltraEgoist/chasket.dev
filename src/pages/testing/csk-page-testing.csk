  padding-left: 1rem;
  margin-top: 0.25rem;
}

.toc ul ul li {
  margin: 0.125rem 0;
}

.toc ul ul a {
  font-size: 0.85rem;
  color: var(--c-text-dim);
  padding: 0.375rem 0.5rem;
}

/* Main Content */
.content {
  padding: var(--space-page) 2rem;
  overflow-y: auto;
}

